  "item": [
    {
      "name": "01 - Salles (Room)",
      "item": [
        {
          "name": "Create Room - Salle Alpha (MEETING_ROOM)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/rooms",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Salle Alpha\",\n  \"city\": \"Paris\",\n  \"capacity\": 10,\n  \"type\": \"MEETING_ROOM\",\n  \"hourlyRate\": 50.00,\n  \"available\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Room create status is 201', function () { pm.response.to.have.status(201); });",
                  "const j = pm.response.json();",
                  "pm.environment.set('roomIdSalleAlpha', j.id);"
                ]
              }
            }
          ]
        },
