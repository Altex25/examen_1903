                ]
              }
            }
          ]
        },
        {
          "name": "Get All Reservations (expect empty array)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reservations"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('All reservations should be deleted for member', function () {",
                  "  const r = pm.response.json();",
                  "  pm.expect(Array.isArray(r)).to.eql(true);",
                  "  pm.expect(r.length).to.eql(0);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
