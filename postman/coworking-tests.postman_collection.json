{
  "info": {
    "name": "Coworking - Tests (Gateway)",
    "_postman_id": "c6c0b4d2-8f5d-4ad6-9f3f-1a9e8d0c2db2",
    "description": "Collection Postman pour tester l'application via API Gateway (http://localhost:8080).",
